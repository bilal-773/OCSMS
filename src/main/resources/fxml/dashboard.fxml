<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ocsms.gui.controllers.DashboardController"
            style="-fx-background-color: #060912;"
            prefWidth="1280" prefHeight="800">

    <!-- ══ TOP NAV BAR ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0a0e1a; -fx-border-color: #1a2240; -fx-border-width: 0 0 1 0; -fx-pref-height: 56;">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>

            <Label text="OCSMS"
                   style="-fx-text-fill: #818cf8; -fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, #818cf8, 10, 0.3, 0, 0);"/>
            <Label text="│" style="-fx-text-fill: #1e2a4a; -fx-font-size: 18px;"/>
            <Label text="FAST-NUCES Peshawar" style="-fx-text-fill: #334155; -fx-font-size: 12px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Notification badge -->
            <Label fx:id="notificationBadge" text="0"
                   style="-fx-background-color: #111d3d; -fx-text-fill: #fbbf24;
                          -fx-padding: 4 12; -fx-background-radius: 20; -fx-font-size: 12px;
                          -fx-font-weight: bold; -fx-cursor: hand;" visible="false"/>

            <!-- User pill -->
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #111d3d; -fx-background-radius: 25; -fx-padding: 5 14;
                         -fx-border-color: #1e2a4a; -fx-border-radius: 25; -fx-border-width: 1;">
                <Label fx:id="navUserLabel" text="User"
                       style="-fx-text-fill: #f1f5f9; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Label fx:id="navRoleLabel" text="[STUDENT]"
                       style="-fx-text-fill: #818cf8; -fx-font-size: 11px;"/>
            </HBox>

            <Button text="Logout"
                    style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 12px;
                           -fx-padding: 6 14; -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 6;
                           -fx-background-radius: 6; -fx-cursor: hand;"
                    onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- ══ LEFT SIDEBAR ══════════════════════════════════════════════════════ -->
    <left>
        <VBox spacing="2" prefWidth="215" minWidth="215"
              style="-fx-background-color: #0a0e1a; -fx-border-color: #1a2240; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="24" right="10" bottom="20" left="10"/></padding>

            <!-- Nav label -->
            <Label text="NAVIGATION"
                   style="-fx-text-fill: #1e2a4a; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 0 6 8 6;"/>

            <Button fx:id="navDashboard"  text="Dashboard"    maxWidth="Infinity" onAction="#showDashboardHome"
                    style="-fx-background-color: #1a2040; -fx-text-fill: #818cf8; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 14;
                           -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: #2d3a6a;
                           -fx-border-width: 1; -fx-border-radius: 8;"/>
            <Button fx:id="navSocieties"  text="Societies"     maxWidth="Infinity" onAction="#showSocieties"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navEvents"     text="Events"        maxWidth="Infinity" onAction="#showEvents"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navMembership" text="Membership"    maxWidth="Infinity" onAction="#showMembership"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navAttendance" text="Attendance"    maxWidth="Infinity" onAction="#showAttendance"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navFinance"    text="Finance"        maxWidth="Infinity" onAction="#showFinance"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navCertificates" text="Certificates" maxWidth="Infinity" onAction="#showCertificates"
                    style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button fx:id="navManagePresidents" text="Manage Presidents" maxWidth="Infinity"
                    onAction="#showManagePresidents"
                    visible="false" managed="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #f59e0b; -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 14; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- User info card -->
            <VBox spacing="4"
                  style="-fx-background-color: #111d3d; -fx-background-radius: 10; -fx-border-color: #1e2a4a;
                         -fx-border-width: 1; -fx-border-radius: 10;">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="SIGNED IN AS" style="-fx-text-fill: #1e2a4a; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                <Label fx:id="sidebarUserName" text="—"
                       style="-fx-text-fill: #f1f5f9; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Label fx:id="sidebarRoll" text="—" style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>
                <Label fx:id="sidebarRole" text="—"
                       style="-fx-text-fill: #818cf8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ MAIN CONTENT AREA ══════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #060912; -fx-background: #060912;">

            <!-- NOTE: Each pane is shown/hidden individually, NOT using StackPane -->
            <VBox fx:id="mainContentVBox" fillWidth="true">

                <!-- ── 1. Dashboard Home ─────────────────────────────────── -->
                <VBox fx:id="dashboardHomePane" spacing="24" visible="true" managed="true">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                    <VBox spacing="4">
                        <Label fx:id="welcomeLabel" text="Welcome back"
                               style="-fx-text-fill: #f1f5f9; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                        <Label text="System status overview for OCSMS — FAST-NUCES Peshawar"
                               style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Stats Row -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" spacing="8"
                              style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                     -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Region prefHeight="3" maxWidth="40"
                                    style="-fx-background-color: #818cf8; -fx-background-radius: 2;"/>
                            <Label fx:id="statSocieties" text="—"
                                   style="-fx-text-fill: #818cf8; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            <Label text="Active Societies" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="8"
                              style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                     -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Region prefHeight="3" maxWidth="40"
                                    style="-fx-background-color: #c084fc; -fx-background-radius: 2;"/>
                            <Label fx:id="statEvents" text="—"
                                   style="-fx-text-fill: #c084fc; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            <Label text="Upcoming Events" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="8"
                              style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                     -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Region prefHeight="3" maxWidth="40"
                                    style="-fx-background-color: #34d399; -fx-background-radius: 2;"/>
                            <Label fx:id="statMembers" text="—"
                                   style="-fx-text-fill: #34d399; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            <Label fx:id="statMembersLabel" text="Members"
                                   style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="8"
                              style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                     -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Region prefHeight="3" maxWidth="40"
                                    style="-fx-background-color: #fbbf24; -fx-background-radius: 2;"/>
                            <Label fx:id="statCerts" text="—"
                                   style="-fx-text-fill: #fbbf24; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                            <Label text="Certificates Issued" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <!-- Two-column: pending + activity -->
                    <HBox spacing="16" VBox.vgrow="ALWAYS">
                        <!-- Pending approvals (Society Admin only) -->
                        <VBox fx:id="pendingApprovalsPane" spacing="10" HBox.hgrow="ALWAYS"
                              visible="false" managed="false">
                            <VBox spacing="8"
                                  style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                         -fx-border-color: #2d1a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Region prefWidth="4" prefHeight="16"
                                            style="-fx-background-color: #fbbf24; -fx-background-radius: 2;"/>
                                    <Label text="Pending Approvals"
                                           style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                </HBox>
                                <ListView fx:id="pendingApprovalsList" prefHeight="160"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                            </VBox>
                        </VBox>

                        <!-- Recent Activity -->
                        <VBox HBox.hgrow="ALWAYS" spacing="10"
                              style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                     -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Region prefWidth="4" prefHeight="16"
                                        style="-fx-background-color: #818cf8; -fx-background-radius: 2;"/>
                                <Label text="Recent Activity"
                                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="LIVE"
                                       style="-fx-text-fill: #34d399; -fx-font-size: 9px; -fx-font-weight: bold;
                                              -fx-background-color: #071a10; -fx-background-radius: 4;
                                              -fx-padding: 2 8; -fx-border-color: #14532d;
                                              -fx-border-width: 1; -fx-border-radius: 4;"/>
                            </HBox>
                            <Separator style="-fx-background-color: #1e2a4a;"/>
                            <ListView fx:id="notificationsList" prefHeight="220" VBox.vgrow="ALWAYS"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        </VBox>
                    </HBox>

                    <!-- Role info card -->
                    <VBox fx:id="roleInfoCard" spacing="10"
                          style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                 -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                        <Label text="Your Access Level" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="roleDescLabel" text="—"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- ── 2. Societies ──────────────────────────────────────── -->
                <VBox fx:id="societiesPane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="societies.fxml" fx:id="societiesInclude"/>
                </VBox>

                <!-- ── 3. Events ─────────────────────────────────────────── -->
                <VBox fx:id="eventsPane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="events.fxml" fx:id="eventsInclude"/>
                </VBox>

                <!-- ── 4. Membership ─────────────────────────────────────── -->
                <VBox fx:id="membershipPane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="membership.fxml" fx:id="membershipInclude"/>
                </VBox>

                <!-- ── 5. Attendance ─────────────────────────────────────── -->
                <VBox fx:id="attendancePane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="attendance.fxml" fx:id="attendanceInclude"/>
                </VBox>

                <!-- ── 6. Finance ────────────────────────────────────────── -->
                <VBox fx:id="financePane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="finance.fxml" fx:id="financeInclude"/>
                </VBox>

                <!-- ── 7. Certificates ───────────────────────────────────── -->
                <VBox fx:id="certificatesPane" spacing="0" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    <fx:include source="certificates.fxml" fx:id="certificatesInclude"/>
                </VBox>

                <!-- ── 8. Manage Presidents (Uni Admin only) ────────────── -->
                <VBox fx:id="managePresidentsPane" spacing="20" visible="false" managed="false">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Manage Society Presidents"
                               style="-fx-text-fill: #f1f5f9; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Create, view, and remove Society President accounts. Presidents can login and create/manage their society."
                           style="-fx-text-fill: #475569; -fx-font-size: 13px;" wrapText="true"/>

                    <!-- Add President Form -->
                    <VBox fx:id="addPresidentForm" spacing="14"
                          style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                 -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Add New Society President"
                               style="-fx-text-fill: #818cf8; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="FULL NAME" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="presNameField" promptText="e.g. Ali Hassan"
                                           styleClass="form-field"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="ROLL NUMBER" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="presRollField" promptText="21F-3456"
                                           styleClass="form-field"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="EMAIL" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="presEmailField" promptText="president@nu.edu.pk"
                                           styleClass="form-field"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="PASSWORD (set by admin)" style="-fx-text-fill: #64748b; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="presPasswordField" promptText="Min 6 characters"
                                           styleClass="form-field"/>
                            </VBox>
                        </HBox>

                        <Label fx:id="presErrorLabel" text=""
                               style="-fx-text-fill: #f87171; -fx-font-size: 12px;"/>
                        <Button fx:id="addPresidentBtn" text="Create President Account"
                                styleClass="btn-primary" onAction="#handleAddPresident"/>
                    </VBox>

                    <!-- Presidents Table -->
                    <VBox spacing="10"
                          style="-fx-background-color: #0d1433; -fx-background-radius: 12;
                                 -fx-border-color: #1e2a4a; -fx-border-width: 1; -fx-border-radius: 12;">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="Current Society Presidents"
                               style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <TableView fx:id="presidentsTable" styleClass="data-table" prefHeight="280">
                            <columns>
                                <TableColumn fx:id="colPresName"   text="Name"        prefWidth="180"/>
                                <TableColumn fx:id="colPresRoll"   text="Roll No."    prefWidth="120"/>
                                <TableColumn fx:id="colPresEmail"  text="Email"       prefWidth="220"/>
                                <TableColumn fx:id="colPresSociety" text="Society"    prefWidth="180"/>
                                <TableColumn fx:id="colPresStatus" text="Status"      prefWidth="80"/>
                            </columns>
                            <placeholder><Label text="No presidents added yet." styleClass="table-placeholder"/></placeholder>
                        </TableView>
                        <HBox spacing="10">
                            <Button fx:id="removePresidentBtn" text="Remove Selected"
                                    styleClass="btn-danger" onAction="#handleRemovePresident"/>
                        </HBox>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
